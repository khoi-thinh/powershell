$targetServer = "TARGET-SERVER"

$accounts = @(
    @{User="DOMAIN\svc_robot1"; Pass="Password1"},
    @{User="DOMAIN\svc_robot2"; Pass="Password2"},
    @{User="DOMAIN\svc_robot3"; Pass="Password3"},
    @{User="DOMAIN\svc_robot4"; Pass="Password4"},
    @{User="DOMAIN\svc_robot5"; Pass="Password5"},
    @{User="DOMAIN\svc_robot6"; Pass="Password6"},
    @{User="DOMAIN\svc_robot7"; Pass="Password7"},
    @{User="DOMAIN\svc_robot8"; Pass="Password8"},
    @{User="DOMAIN\svc_robot9"; Pass="Password9"},
    @{User="DOMAIN\svc_robot10"; Pass="Password10"}
)

Invoke-Command -ComputerName $targetServer -ScriptBlock {

    param($accounts)

    foreach ($account in $accounts) {

        $username = $account.User
        $password = $account.Pass

        Write-Host "Installing certificate for $username"

        $securePassword = ConvertTo-SecureString $password -AsPlainText -Force
        $cred = New-Object System.Management.Automation.PSCredential ($username,$securePassword)

        Start-Process powershell `
            -Credential $cred `
            -ArgumentList "-ExecutionPolicy Bypass -File C:\scripts\install-cert.ps1" `
            -Wait
    }

} -ArgumentList $accounts



$password = ConvertTo-SecureString "PfxPassword" -AsPlainText -Force

Import-PfxCertificate `
 -FilePath "C:\certs\robotcert.pfx" `
 -CertStoreLocation Cert:\CurrentUser\My `
 -Password $password
